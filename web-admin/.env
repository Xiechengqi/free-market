# Vue SPA mounted under /admin/ in production. Trailing slash required.
VITE_BASE_URL=/admin/

VITE_APP_TITLE=freeMarket 后台
VITE_APP_DESC=freeMarket 后台管理

VITE_ICON_PREFIX=icon
VITE_ICON_LOCAL_PREFIX=icon-local

# static = local route table (we don't expose a dynamic /route endpoint)
VITE_AUTH_ROUTE_MODE=static
VITE_ROUTE_HOME=home
VITE_MENU_ICON=mdi:menu

VITE_HTTP_PROXY=Y
VITE_ROUTER_HISTORY_MODE=history

# matches src/web/admin/api/response.rs constants
VITE_SERVICE_SUCCESS_CODE=0000
VITE_SERVICE_LOGOUT_CODES=4002,8888,8889
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999

VITE_STATIC_SUPER_ROLE=owner

VITE_SOURCE_MAP=N
VITE_STORAGE_PREFIX=FREEMARKET_
VITE_AUTOMATICALLY_DETECT_UPDATE=N
VITE_PROXY_LOG=Y
VITE_DEVTOOLS_LAUNCH_EDITOR=code
